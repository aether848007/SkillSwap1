# SkillSwap Environment Variables
# Copy this file to .env and fill in your values (never commit .env)

# Database (PostgreSQL)
DATABASE_URL=jdbc:postgresql://localhost:5432/skillswap
DATABASE_USERNAME=skillswap
DATABASE_PASSWORD=change_me_strong_password

# JWT — generate with: openssl rand -base64 64
JWT_SECRET=change_me_very_long_random_secret_at_least_256_bits

# Spring profile: "postgres" for production, leave blank for H2 dev
SPRING_PROFILES_ACTIVE=postgres

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Google Maps (frontend)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
