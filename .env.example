# SkillSwap deployment environment.
# Copy to `.env` and fill in real values. Never commit `.env`.

# --- Required ---

# 256-bit (32+ byte) random string. Generate with:
#   openssl rand -base64 48
JWT_SECRET=

# Postgres credentials. Used by both the `db` and `backend` services.
DATABASE_USERNAME=skillswap
DATABASE_PASSWORD=

# Comma-separated list of origins allowed to call the API.
# Production example: https://skillswap.example.com
CORS_ALLOWED_ORIGINS=http://localhost

# --- Frontend build ---

# Where the frontend should send API calls. For the compose setup with the
# bundled nginx, leave this as `/api` (same-origin proxy). For a split deploy,
# set the absolute URL: https://skillswap.example.com/api
VITE_API_BASE_URL=/api

# --- Optional: Google OAuth ---

# Leave empty to disable Google sign-in.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
